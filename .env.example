TELEGRAM_BOT_TOKEN=
TG_USER_1=
TG_USER_2=
TG_CHAT_ID=
PROJECT_ROOT=
DATA_PATH=
VAULT_PATH=
CLAUDE_BIN=

# Raspberry Pi WiFi fix: Node.js 22 Happy Eyeballs causes TLS timeouts when there is no IPv6 routing.
# Set to true on the Pi, leave blank or false on dev machines.
DISABLE_IPV6=
# NODE_OPTIONS loads fix-network.cjs for child processes (e.g. claude -p) — set automatically by pi-setup.sh
NODE_OPTIONS=

# Backups (M9) — rclone encrypted Google Drive remote
# Run 'rclone config' on the Pi to set these up (see scripts/backup.sh header)
RCLONE_BIN=rclone
RCLONE_REMOTE=gdrive

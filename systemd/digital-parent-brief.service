[Unit]
Description=Digital Parent Morning Brief
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=digital-parent
WorkingDirectory=/opt/digital-parent
EnvironmentFile=/opt/digital-parent/bot/.env
ExecStart=/opt/digital-parent/scripts/morning-brief.sh
StandardOutput=journal
StandardError=journal
SyslogIdentifier=digital-parent-brief
